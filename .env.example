# Salient — environment variables
# Single-player runs fully client-side (localStorage); no env needed.
# These are for the upcoming multiplayer + cloud-save backend (Supabase).

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER prefix these with NEXT_PUBLIC_, set in Vercel as secrets)
SUPABASE_SERVICE_ROLE_KEY=
